# ============================================
# African Markets MCP — Configuration
# ============================================

# --- Abonnement african-markets.com ---
# Identifiants de votre compte premium
AFRICAN_MARKETS_USERNAME=votre_email@example.com
AFRICAN_MARKETS_PASSWORD=votre_mot_de_passe

# --- Serveur ---
AFRICAN_MARKETS_BASE_URL=https://www.african-markets.com/fr
HTTP_PORT=3100
LOG_LEVEL=info

# --- Cache ---
CACHE_TTL_SECONDS=300
CACHE_TTL_REPORTS_SECONDS=3600
CACHE_TTL_PROFILES_SECONDS=1800

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# --- Cache Warmer (préchauffage proactif) ---
# Met à jour les données de façon proactive en arrière-plan :
#   - Pendant les heures de trading (un marché ouvert) : toutes les 5 minutes
#   - En dehors des heures de marché (nuits / week-ends) : toutes les heures
# Désactiver en environnement serverless (Vercel, Lambda) : CACHE_WARMING_ENABLED=false
CACHE_WARMING_ENABLED=true

# --- Redis (cache L2 — optionnel) ---
# Si défini, active le cache Redis en plus du cache mémoire.
# Laisser vide pour désactiver Redis (cache mémoire seul).
REDIS_URL=

# --- Admin (endpoint /admin/warm) ---
# Secret pour déclencher manuellement le préchauffage du cache.
# Laisser vide pour désactiver les appels manuels (seul Vercel Cron sera autorisé).
MCP_ADMIN_SECRET=

# --- Sécurité MCP ---
# Clés API pour l'authentification Bearer sur /mcp (liste séparée par virgules).
# Laisser vide pour désactiver l'auth (mode stdio/dev — non recommandé en production).
# Exemple : MCP_API_KEYS=cle-app-1,cle-app-2
MCP_API_KEYS=

# Origins CORS autorisées pour /mcp (liste séparée par virgules).
# Laisser vide pour autoriser toutes les origins (Access-Control-Allow-Origin: *).
# Exemple : MCP_ALLOWED_ORIGINS=https://mon-app.com,https://staging.mon-app.com
MCP_ALLOWED_ORIGINS=

# Limite de requêtes par minute par clé API sur /mcp. 0 = désactivé.
MCP_INBOUND_RATE_LIMIT=60
