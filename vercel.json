{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "env": {
    "AFRICAN_MARKETS_BASE_URL": "https://www.african-markets.com/fr",
    "CACHE_TTL_SECONDS": "300",
    "RATE_LIMIT_REQUESTS_PER_MINUTE": "30",
    "LOG_LEVEL": "info"
  }
}
